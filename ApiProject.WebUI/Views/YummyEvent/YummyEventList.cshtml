@model List<ResultYummyEventDto>
@{
    ViewData["Title"] = "YummyEventList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    .event-card {
        border-radius: 15px;
        transition: all 0.3s ease;
        border: none;
        overflow: hidden;
        background: #fff;
        height: 100%;
    }

        .event-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    .event-img-container {
        position: relative;
        height: 200px;
        overflow: hidden;
    }

    .event-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .event-card:hover .event-img {
        transform: scale(1.1);
    }

    .status-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        z-index: 1;
    }

    .price-tag {
        position: absolute;
        bottom: 15px;
        left: 15px;
        background: rgba(102, 126, 234, 0.9);
        color: white;
        padding: 0.4rem 1rem;
        border-radius: 8px;
        font-weight: 700;
        backdrop-filter: blur(5px);
    }

    .event-body {
        padding: 1.5rem;
    }

    .event-title {
        font-weight: 700;
        color: #333;
        margin-bottom: 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .event-text {
        color: #666;
        font-size: 0.875rem;
        line-height: 1.5;
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 4.5em;
    }

    .modern-btn {
        padding: 0.5rem 0.8rem;
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        flex: 1;
        justify-content: center;
    }

    .btn-create {
        background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 700;
    }

    .btn-edit {
        background: #667eea;
        color: white;
    }

    .btn-delete {
        background: #f5576c;
        color: white;
    }

    .btn-view {
        background: #4facfe;
        color: white;
    }

    .modern-btn:hover {
        opacity: 0.9;
        transform: translateY(-2px);
    }
</style>

<section class="section">
    <div class="section-body">
        <div class="row align-items-center mb-4">
            <div class="col-md-8 col-12">
                <h2 class="section-title m-0">Event Organizations</h2>
                <br />
                <p class="section-lead mb-0">Manage your restaurant events and special celebrations.</p>
            </div>
            <div class="col-md-4 col-12 text-md-end text-start mt-3 mt-md-0">
                <a href="/YummyEvent/CreateYummyEvent/" class="modern-btn btn-create shadow-sm w-100">
                    <i class="fas fa-plus"></i> Add New Event
                </a>
            </div>
        </div>

        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 mb-4">
                    <div class="card event-card shadow-sm border-0">
                        <div class="event-img-container">
                            @if (item.Status)
                            {
                                <span class="badge badge-success status-badge shadow-sm">Active</span>
                            }
                            else
                            {
                                <span class="badge badge-danger status-badge shadow-sm">Passive</span>
                            }

                            <img src="@item.ImageUrl" class="event-img" alt="@item.Title">

                            <div class="price-tag shadow-sm">
                                <i class="fas fa-euro-sign me-1"></i> @item.Price.ToString("N2")
                            </div>
                        </div>

                        <div class="event-body">
                            <h5 class="event-title">@item.Title</h5>
                            <p class="event-text">@item.Description</p>

                            <div class="d-flex gap-2">
                                <a href="/YummyEvent/ViewYummyEvent/@item.YummyEventId" class="modern-btn btn-view" title="View Details">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="/YummyEvent/UpdateYummyEvent/@item.YummyEventId" class="modern-btn btn-edit" title="Edit Event">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a href="/YummyEvent/DeleteYummyEvent/@item.YummyEventId" class="modern-btn btn-delete"
                                   onclick="return confirm('Are you sure you want to delete this event?');" title="Delete Event">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>