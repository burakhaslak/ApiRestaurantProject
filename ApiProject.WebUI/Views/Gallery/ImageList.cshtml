@model List<ResultImageDto>
@{
    ViewData["Title"] = "ImageList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    /* Chef sayfasındaki kart stiliyle birebir uyumlu */
    .gallery-card {
        border-radius: 20px;
        transition: all 0.3s ease;
        border: none;
        background: #fff;
        height: 100%;
        overflow: hidden;
    }

        .gallery-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
        }

    /* Chef sayfasındaki aspect-ratio yapısı */
    .gallery-img-wrapper {
        position: relative;
        aspect-ratio: 4 / 3;
        overflow: hidden;
    }

    .gallery-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .gallery-card:hover .gallery-img {
        transform: scale(1.1);
    }

    /* Chef sayfasındaki modern buton stilleri */
    .modern-btn {
        padding: 0.6rem;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.3s ease;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        text-decoration: none;
    }

    .btn-edit {
        background: #e8ecff;
        color: #667eea;
    }

    .btn-delete {
        background: #fff1f2;
        color: #f5576c;
    }

    .modern-btn:hover {
        transform: translateY(-2px);
        filter: brightness(0.95);
        text-decoration: none;
    }

    /* Satırı kaplayan ana aksiyon butonu */
    .btn-create-full {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 1rem;
        border-radius: 15px;
        font-weight: 700;
        text-align: center;
        display: block;
        width: 100%;
        margin-bottom: 2rem;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.2);
        transition: all 0.3s ease;
    }

        .btn-create-full:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(102, 126, 234, 0.3);
            color: #fff;
            text-decoration: none;
        }

    /* Chef sayfasındaki Header yapısı */
    .gallery-list-header {
        margin-bottom: 1.5rem;
    }

        .gallery-list-header .section-title {
            font-weight: 700;
            color: #333;
            margin: 0;
        }

        .gallery-list-header .section-lead {
            margin: 0;
            color: #6c757d;
            font-size: 0.95rem;
        }

    .gallery-body {
        padding: 1.2rem;
        text-align: center;
    }

    .gallery-title {
        font-weight: 700;
        color: #333;
        font-size: 1.1rem;
        margin-bottom: 1rem;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

<section class="section">
    <div class="section-body">

        <div class="gallery-list-header">
            <h2 class="section-title">Gallery Management</h2>
             <br />
            <p class="section-lead">Manage the images displayed in your restaurant's gallery.</p>
        </div>

        <div class="row">
            <div class="col-12">
                <a href="/Gallery/CreateImage/" class="btn-create-full shadow-sm">
                    <i class="fas fa-plus-circle mr-2"></i> Upload New Image
                </a>
            </div>
        </div>

        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-3 mb-4">
                    <div class="card gallery-card shadow-sm">

                        <div class="gallery-img-wrapper">
                            <img src="@item.ImageUrl" class="gallery-img" alt="@item.Title"
                                 onerror="this.src='https://ui-avatars.com/api/?name=Gallery&background=667eea&color=fff&size=512'" />
                        </div>

                        <div class="gallery-body">
                            <span class="gallery-title">@item.Title</span>

                            <div class="d-flex gap-2">
                                <a href="/Gallery/ImageListWithEdit/@item.ImageId" class="modern-btn btn-edit">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a href="/Gallery/DeleteImage/@item.ImageId"
                                   class="modern-btn btn-delete"
                                   onclick="return confirm('Delete this image?');">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="far fa-images fa-4x text-light mb-3"></i>
                <h4 class="text-muted">No images found in gallery.</h4>
            </div>
        }

    </div>
</section>