@model List<ResultReservationDto>
@{
    ViewData["Title"] = "ReservationList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<style>
    /* ── Card ────────────────────────────────────── */
    .reservation-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07);
    }

        .reservation-card .card-header {
            background: #fff;
            border-bottom: 2px solid #f3f4ff;
            padding: 1.4rem 1.8rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.8rem;
        }

            .reservation-card .card-header h4 {
                font-weight: 700;
                color: #333;
                font-size: 1.15rem;
                margin: 0;
            }

    .reservation-count-badge {
        background: #e8ecff;
        color: #667eea;
        font-size: 0.78rem;
        font-weight: 600;
        padding: 0.25rem 0.7rem;
        border-radius: 20px;
    }

    /* ── Table ───────────────────────────────────── */
    .reservation-table {
        width: 100%;
        /* table-layout: fixed;  <-- BU SATIRI SİLİN VEYA YORUMA ALIN */
        border-collapse: separate;
        border-spacing: 0;
        font-size: 0.9rem;
    }

        /* Sütun genişlikleri */
        .reservation-table col.col-num {
            width: 5%;
        }

        .reservation-table col.col-name {
            width: 20%;
        }

        .reservation-table col.col-date {
            width: 15%;
        }

        .reservation-table col.col-time {
            width: 10%;
        }

        .reservation-table col.col-guests {
            width: 10%;
        }

        .reservation-table col.col-status {
            width: 10%;
        }

        .reservation-table col.col-actions {
            width: 30%;
        }

        .reservation-table thead tr {
            background: #f8f8ff;
        }

        .reservation-table thead th {
            padding: 0.9rem 1rem;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #999;
            border: none;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .reservation-table tbody tr {
            border-bottom: 1px solid #f3f4f8;
            transition: background 0.2s;
        }

            .reservation-table tbody tr:last-child {
                border-bottom: none;
            }

            .reservation-table tbody tr:hover {
                background: #fafbff;
            }

        .reservation-table tbody td {
            padding: 1rem 1rem;
            color: #444;
            vertical-align: middle;
            border: none;
            white-space: nowrap;
        }

    .row-num {
        color: #bbb;
        font-weight: 600;
        font-size: 0.85rem;
    }

    .guest-name {
        font-weight: 600;
        color: #333;
        white-space: normal; /* Nowrap yerine normal yaparsak çok uzun isimler tabloyu bozmaz */
    }

    /* ── Status Badge ────────────────────────────── */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 0.3rem 0.75rem;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 600;
    }

        .status-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            display: inline-block;
        }

    .status-confirmed {
        background: #e6f9f0;
        color: #28a745;
    }

        .status-confirmed::before {
            background: #28a745;
        }

    .status-cancelled {
        background: #fff1f2;
        color: #f5576c;
    }

        .status-cancelled::before {
            background: #f5576c;
        }

    .status-pending {
        background: #fff8e6;
        color: #f5a623;
    }

        .status-pending::before {
            background: #f5a623;
        }

    .status-default {
        background: #f0f0f0;
        color: #888;
    }

        .status-default::before {
            background: #aaa;
        }

    /* ── Action Buttons ──────────────────────────── */
    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 0.38rem 0.65rem;
        border-radius: 8px;
        font-size: 0.78rem;
        font-weight: 600;
        text-decoration: none;
        transition: filter 0.2s, transform 0.2s;
        white-space: nowrap;
    }

        .action-btn:hover {
            filter: brightness(0.92);
            transform: translateY(-1px);
            text-decoration: none;
        }

    .ab-update {
        background: #e8ecff;
        color: #667eea;
    }

    .ab-delete {
        background: #fff1f2;
        color: #f5576c;
    }

    .ab-confirm {
        background: #e6f9f0;
        color: #28a745;
    }

    .ab-cancel {
        background: #f5f5f5;
        color: #555;
    }

    .ab-pending {
        background: #fff8e6;
        color: #f5a623;
    }

    .actions-cell {
        display: flex;
        gap: 5px;
        flex-wrap: nowrap;
        align-items: center;
    }

    /* Actions td tam genişliği kullansın */
    .reservation-table td.td-actions {
        width: 100%;
    }

    /* ── Date / Time ─────────────────────────────── */
    .date-cell {
        display: flex;
        flex-direction: column;
        gap: 1px;
    }

    .date-main {
        font-weight: 600;
        color: #444;
    }

    .date-sub {
        font-size: 0.78rem;
        color: #aaa;
    }

    /* ── Guest count ─────────────────────────────── */
    .guest-count {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        color: #667eea;
        font-weight: 600;
    }

    /* ── Empty state ─────────────────────────────── */
    .empty-row td {
        padding: 4rem 1rem;
        text-align: center;
        color: #bbb;
    }

    /* ── Scrollable on small screens ─────────────── */
    .table-scroll {
        width: 100%;
        overflow-x: auto;
    }
</style>

<section class="section">
    <div class="section-body">
        <div class="row">
            <div class="col-12">
                <div class="card reservation-card">

                    <div class="card-header">
                        <h4><i class="fas fa-calendar-alt me-2" style="color:#667eea"></i> Reservation List</h4>
                        @if (Model.Any())
                        {
                            <span class="reservation-count-badge">@Model.Count reservation@(Model.Count != 1 ? "s" : "")</span>
                        }
                    </div>

                    <div class="card-body p-0">
                        <div class="table-scroll">
                            <table class="reservation-table">
                                <colgroup>
                                    <col class="col-num" />
                                    <col class="col-name" />
                                    <col class="col-date" />
                                    <col class="col-time" />
                                    <col class="col-guests" />
                                    <col class="col-status" />
                                    <col class="col-actions" />
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Name &amp; Surname</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Guests</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Any())
                                    {
                                        @foreach (var item in Model)
                                        {
                                            count++;

                                            // Status badge sınıfı
                                            string statusClass = item.ReservationStatus?.ToLower() switch
                                            {
                                                "confirmed" or "accepted" or "onaylandı" => "status-confirmed",
                                                "cancelled" or "iptal" => "status-cancelled",
                                                "pending" or "beklemede" => "status-pending",
                                                _ => "status-default"
                                            };

                                            <tr>
                                                <td class="row-num">@count</td>

                                                <td class="guest-name">@item.NameSurname</td>

                                                <td>
                                                    <div class="date-cell">
                                                        <span class="date-main">@item.ReservationDate.ToString("dd MMM yyyy")</span>
                                                        <span class="date-sub">@item.ReservationDate.ToString("dddd")</span>
                                                    </div>
                                                </td>

                                                <td>@item.ReservationTime</td>

                                                <td>
                                                    <span class="guest-count">
                                                        <i class="fas fa-user-friends" style="font-size:0.8rem"></i>
                                                        @item.GuestCount
                                                    </span>
                                                </td>

                                                <td>
                                                    <span class="status-badge @statusClass">@item.ReservationStatus</span>
                                                </td>

                                                <td class="td-actions">
                                                    <div class="actions-cell">
                                                        <a href="/Reservation/UpdateReservation/@item.ReservationId/" class="action-btn ab-update" title="Update">
                                                            <i class="fas fa-pen"></i> Update
                                                        </a>
                                                        <a href="/Reservation/AcceptReservation/@item.ReservationId/" class="action-btn ab-confirm" title="Confirm">
                                                            <i class="fas fa-check"></i> Confirm
                                                        </a>
                                                        <a href="/Reservation/PendReservation/@item.ReservationId/" class="action-btn ab-pending" title="Pending">
                                                            <i class="fas fa-clock"></i> Pending
                                                        </a>
                                                        <a href="/Reservation/CancelReservation/@item.ReservationId/" class="action-btn ab-cancel" title="Cancel">
                                                            <i class="fas fa-ban"></i> Cancel
                                                        </a>
                                                        <a href="/Reservation/DeleteReservation/@item.ReservationId/"
                                                           class="action-btn ab-delete"
                                                           onclick="return confirm('Delete @item.NameSurname\'s reservation?');"
                                                           title="Delete">
                                                            <i class="fas fa-trash"></i> Delete
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr class="empty-row">
                                            <td colspan="7">
                                                <i class="fas fa-calendar-times fa-3x mb-3 d-block"></i>
                                                No reservations found.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
