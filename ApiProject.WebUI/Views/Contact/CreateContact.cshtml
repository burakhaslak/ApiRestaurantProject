@model CreateContactDto
@{
    ViewData["Title"] = "CreateContact";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
	<div class="section-body">
		<div class="row">
			<div class="col-12 col-md-12 col-lg-12">
				<div class="card">
					<div class="card-header">
						<h4>Adding Contact Info</h4>
					</div>
					<div class="card-body">
						<form method="post">
							<label>Address</label>
							<input type="text" asp-for="Address" class="form-control" />
							<br />
							<label>Phone</label>
							<input type="text" asp-for="PhoneNumber" class="form-control" />
							<br />
							<label>Email</label>
							<input type="text" asp-for="Email" class="form-control" />
							<br />
							<label>Available Hours</label>
							<input type="text" asp-for="OpenHours" class="form-control" />
							<br />
							<label>Location</label>
							<input type="text" asp-for="MapLocation" class="form-control" />
							<br />
							<button class="btn btn-outline-primary">Create the Contact Info</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>


