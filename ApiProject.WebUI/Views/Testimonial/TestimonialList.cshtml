@model List<ResultTestimonialDto>
@{
    ViewData["Title"] = "TestimonialList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<style>
    .testimonial-card {
        border-radius: 20px;
        transition: all 0.3s ease;
        border: none;
        background: #fff;
        height: 100%;
        position: relative;
        overflow: visible;
    }

        .testimonial-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 30px rgba(102, 126, 234, 0.15) !important;
        }

    .user-img-wrapper {
        width: 90px;
        height: 90px;
        margin: -45px auto 15px;
        position: relative;
        z-index: 2;
    }

    .user-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
        border: 5px solid #fff;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .quote-icon {
        position: absolute;
        top: 20px;
        right: 20px;
        font-size: 2rem;
        color: #667eea;
        opacity: 0.1;
    }

    .testimonial-body {
        padding: 2rem 1.5rem 1.5rem;
        text-align: center;
    }

    .user-name {
        font-weight: 700;
        color: #333;
        margin-bottom: 0.25rem;
        font-size: 1.1rem;
    }

    .user-title {
        color: #667eea;
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 1rem;
        display: block;
    }

    .user-comment {
        color: #666;
        font-size: 0.9rem;
        line-height: 1.6;
        font-style: italic;
        margin-bottom: 1.5rem;
        display: -webkit-box;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        overflow: hidden;
        height: 6em;
    }

    .rating-stars {
        color: #ffa726;
        margin-bottom: 1.5rem;
    }

    .card-actions {
        border-top: 1px solid #f0f0f0;
        padding-top: 1rem;
        display: flex;
        gap: 8px;
    }

    .modern-btn {
        padding: 0.5rem;
        border-radius: 10px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all 0.3s ease;
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        text-decoration: none;
    }

    .btn-edit {
        background: #e8ecff;
        color: #667eea;
    }

    .btn-delete {
        background: #fff1f2;
        color: #f5576c;
    }

    .btn-view {
        background: #f0fdf4;
        color: #16a34a;
    }

    .modern-btn:hover {
        transform: translateY(-2px);
        filter: brightness(0.95);
    }

    .btn-create {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 700;
    }
</style>

<section class="section">
    <div class="section-body">
        <div class="row align-items-center mb-5">
            <div class="col-md-8">
                <h2 class="section-title m-0">Customer Testimonials</h2>
                <br />
                <p class="section-lead">Manage reviews and feedback from your valued guests.</p>
            </div>
            <div class="col-md-4 text-md-end">
                <a href="/Testimonial/CreateTestimonial/" class="modern-btn btn-create shadow-sm d-inline-flex">
                    <i class="fas fa-plus"></i> Add New Testimonial
                </a>
            </div>
        </div>

        <div class="row" style="margin-top: 50px;">
            @foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 mb-5">
                    <div class="card testimonial-card shadow-sm">
                        <i class="fas fa-quote-right quote-icon"></i>

                        <div class="user-img-wrapper">
                            <img src="@item.ImageUrl" class="user-img" alt="@item.NameSurname"
                                 onerror="this.src='https://ui-avatars.com/api/?name=@item.NameSurname&background=667eea&color=fff'">
                        </div>

                        <div class="testimonial-body">
                            <span class="user-name">@item.NameSurname</span>
                            <span class="user-title">@item.Title</span>

                            <div class="rating-stars">
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                                <i class="fas fa-star"></i>
                            </div>

                            <p class="user-comment">"@item.Comment"</p>

                            <div class="card-actions">
                                <a href="/Testimonial/ViewTestimonial/@item.TestimonialId" class="modern-btn btn-view">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="/Testimonial/UpdateTestimonial/@item.TestimonialId" class="modern-btn btn-edit">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a href="/Testimonial/DeleteTestimonial/@item.TestimonialId" class="modern-btn btn-delete"
                                   onclick="return confirm('Delete this testimonial?');">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>