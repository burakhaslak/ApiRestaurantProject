@model CreateTestimonialDto
@{
    ViewData["Title"] = "CreateTestimonial";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<section class="section">
	<div class="section-body">
		<div class="row">
			<div class="col-12 col-md-12 col-lg-12">
				<div class="card">
					<div class="card-header">
						<h4>Adding Testimonials</h4>
					</div>
					<div class="card-body">
						<form method="post">
							<label>Name and Surname</label>
							<input type="text" asp-for="NameSurname" class="form-control" />
							<br />
							<label>Title</label>
							<input type="text" asp-for="Title" class="form-control" />
							<br />
							<label>Comment</label>
							<input type="text" asp-for="Comment" class="form-control" />
							<br />
							<label>Profil Photo</label>
							<input type="text" asp-for="ImageUrl" class="form-control" />
							<br />
							<button class="btn btn-outline-primary">Create the Testimonial</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

